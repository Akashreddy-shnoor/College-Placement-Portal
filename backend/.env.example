# College Placement Portal Backend Configurations

# 1. PostgreSQL Database Connection URL
# Replace 'postgres', 'password', and 'placement_portal' with your local PostgreSQL credentials
DATABASE_URL=postgresql://postgres:password@localhost:5432/placement_portal

# 2. OpenAI API Key Configuration
# Provide your active OpenAI API key here to enable dynamic GPT-4o resume analysis.
# Leave blank or modify with 'your_openai_api_key_here' to test using the offline fallback analyzer!
OPENAI_API_KEY=your_openai_api_key_here
